{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"$components/*": ["src/components/*"],
			"$styles/*": ["src/styles/*"],
			"$lib/*": ["src/lib/*"],
			"$layouts/*": ["src/layouts/*"]
		},
		"jsx": "preserve",
		"jsxImportSource": "solid-js"
	},
	"exclude": ["node_modules", "dist", "public"]
}
